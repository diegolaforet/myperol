---
const { lang = "es" } = Astro.props;

const brochureSrc = `/assets/brochure-${lang}.jpg`;
---

<section class="brochure-wrapper">
  <div class="brochure">
    <img
      src="/assets/brochures/brochure-es1.jpg"
      alt="Brochure MyPerol page 1"
      class="brochure-image"
      id="brochureImage1"
    />

    <img
      src="/assets/brochures/brochure-es2.jpg"
      alt="Brochure MyPerol page 2"
      class="brochure-image"
      id="brochureImage2"
    />
  </div>

  <!-- Controles de zoom -->
  <div class="zoom-controls">
    <button onclick="zoomOut()">−</button>
    <button onclick="zoomIn()">+</button>
  </div>
</section>



