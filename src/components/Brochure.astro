<section class="brochure-wrapper">
  <div class="brochure">
    <img
      src="/assets/brochures/brochure-es1.jpg"
      alt="Brochure MyPerol page 1"
      class="brochure-image"
      id="brochureImage1"
    />

    <img
      src="/assets/brochures/brochure-es2.jpg"
      alt="Brochure MyPerol page 2"
      class="brochure-image"
      id="brochureImage2"
    />
  </div>

  <!-- Controles de zoom -->
  <div class="zoom-controls">
    <button type="button" onclick="zoomOut()" aria-label="Reducir zoom">−</button>
    <button type="button" onclick="zoomIn()" aria-label="Aumentar zoom">+</button>
  </div>
</section>



